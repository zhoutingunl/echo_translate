# EchoTranslate configuration — copy to .env and fill in.
# .env is git-ignored; NEVER commit real keys.

# ---- Primary AI backend: MiniMax (Anthropic-compatible endpoint) ----
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=sk-cp-your-key-here
# Fast, no-thinking model — best for real-time translation.
MINIMAX_MODEL=MiniMax-Text-01
# Higher-quality fallback (emits thinking blocks, slower).
MINIMAX_FALLBACK_MODEL=MiniMax-M2

# ---- Secondary AI backend: Hermes WebUI (failover on 429 / outage) ----
# Leave HERMES_ENABLED=0 to disable. Reachable on company VPN only.
HERMES_ENABLED=0
HERMES_BASE=http://10.210.32.30:8787
HERMES_MODEL=MiniMax-M3

# ---- Bailian / DashScope cloud ASR (browser fallback) ----
# Used as the ASR for Safari / Firefox (no Web Speech API), and optional for
# Chrome / Edge. Leave DASHSCOPE_API_KEY empty to disable the cloud path entirely
# (Chrome/Edge then still work via the browser's Web Speech API).
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
ASR_SAMPLE_RATE=16000

# ---- Server ----
HOST=127.0.0.1
PORT=8000
DEBUG=0

# ---- Storage ----
DB_PATH=data/echo.db

# ---- Pipeline tuning ----
# Subtitles within this many seconds may still be rolled back / corrected.
REVISION_WINDOW_SEC=5
# How many recent segments are fed to the translator as context.
CONTEXT_SEGMENTS=4
# AI request timeout (seconds) and retry count.
AI_TIMEOUT_SEC=20
AI_RETRIES=2
